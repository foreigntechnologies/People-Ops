{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
        "job-service-route": {
          "ClusterId": "job-service-cluster",
          "CorsPolicy": "PeopleOpsDefault",
          "Match": {
            "Path": "/api/jobs/{**remainder}"
          }
        },
        "identity-service-route": {
          "ClusterId": "identity-service-cluster",
          "CorsPolicy": "PeopleOpsDefault",
          "Match": {
            "Path": "/api/identity/{**remainder}"
          }
        },
        "company-service-route": {
          "ClusterId": "company-service-cluster",
          "CorsPolicy": "PeopleOpsDefault",
          "Match": {
            "Path": "/api/companies/{**remainder}"
          }
        },
        "candidate-service-route": {
          "ClusterId": "candidate-service-cluster",
          "CorsPolicy": "PeopleOpsDefault",
          "Match": {
            "Path": "/api/candidates/{**remainder}"
          }
        },
        "application-service-route": {
          "ClusterId": "application-service-cluster",
          "CorsPolicy": "PeopleOpsDefault",
          "Match": {
            "Path": "/api/applications/{**remainder}"
          }
        }
    },
    "Clusters": {
      "identity-service-cluster": { "Destinations": { "destination1": { "Address": "http://identity:8080" } } },
      "job-service-cluster": { "Destinations": { "destination1": { "Address": "http://job:8080" } } },
      "company-service-cluster": { "Destinations": { "destination1": { "Address": "http://company:8080" } } },
      "application-service-cluster": { "Destinations": { "destination1": { "Address": "http://application:8080" } } },
      "candidate-service-cluster": { "Destinations": { "destination1": { "Address": "http://candidate:8080" } } }
    }
  }
}
